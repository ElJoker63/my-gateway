# ===========================================================
# AI Agent Gateway — Configuration
# ===========================================================
# Copy this file to .env and fill in your values.
# ===========================================================

# --- Gateway Authentication ---
# Set a secure key. Agents pass this as Bearer token.
# Leave as default to disable authentication.
GATEWAY_API_KEY=change-me-to-a-secure-key

# --- NVIDIA Provider ---
# Single key (backward compatible)
NVIDIA_API_KEY=
# Multiple keys (JSON array) — overrides NVIDIA_API_KEY if set
# NVIDIA_API_KEYS=["nvapi-key1","nvapi-key2","nvapi-key3"]
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# --- OpenAI Provider (optional) ---
# Single key (backward compatible)
OPENAI_API_KEY=
# Multiple keys (JSON array) — overrides OPENAI_API_KEY if set
# OPENAI_API_KEYS=["sk-key1","sk-key2"]
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Default Provider ---
# Which provider to use when not specified in request
DEFAULT_PROVIDER=nvidia

# --- Rate Limiting ---
# Global RPM limit (used if KEY_RPM_LIMIT is 0)
MAX_REQUESTS_PER_MINUTE=35
RATE_LIMIT_WAIT_TIMEOUT=60

# --- Key Management ---
# Per-key RPM limit (0 = use MAX_REQUESTS_PER_MINUTE)
KEY_RPM_LIMIT=0
# Key selection strategy: 'least_used' or 'round_robin'
KEY_SELECTION_STRATEGY=least_used
# Seconds to cool down a key after an error
KEY_ERROR_COOLDOWN=60

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Qdrant ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=

# --- Cache ---
# Cache TTL in seconds (86400 = 24 hours)
CACHE_TTL=86400

# --- Embedding ---
# 'local' = sentence-transformers (free, runs in container)
# 'nvidia' = NVIDIA embedding API (uses API credits)
EMBEDDING_MODEL=local
LOCAL_EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# --- Context ---
MAX_CONTEXT_TOKENS=4000
MEMORY_SEARCH_TOP_K=10
MEMORY_SCORE_THRESHOLD=0.5

# --- Logging ---
LOG_LEVEL=INFO
