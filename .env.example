# ===========================================================
# AI Agent Gateway — Configuration
# ===========================================================
# Copy this file to .env and fill in your values.
# ===========================================================

# --- Gateway Authentication ---
# Set a secure key. Agents pass this as Bearer token.
# Leave as default to disable authentication.
GATEWAY_API_KEY=change-me-to-a-secure-key

# --- NVIDIA Provider ---
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# --- OpenAI Provider (optional) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Default Provider ---
# Which provider to use when not specified in request
DEFAULT_PROVIDER=nvidia

# --- Rate Limiting ---
# Stay below provider limits (NVIDIA free = 40 RPM)
MAX_REQUESTS_PER_MINUTE=35
RATE_LIMIT_WAIT_TIMEOUT=60

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Qdrant ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=

# --- Cache ---
# Cache TTL in seconds (86400 = 24 hours)
CACHE_TTL=86400

# --- Embedding ---
# 'local' = sentence-transformers (free, runs in container)
# 'nvidia' = NVIDIA embedding API (uses API credits)
EMBEDDING_MODEL=local
LOCAL_EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# --- Context ---
MAX_CONTEXT_TOKENS=4000
MEMORY_SEARCH_TOP_K=10
MEMORY_SCORE_THRESHOLD=0.5

# --- Logging ---
LOG_LEVEL=INFO
